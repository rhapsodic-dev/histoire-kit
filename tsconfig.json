{
  "compilerOptions": {
    "allowImportingTsExtensions": false,
    "esModuleInterop": true,
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2023",
    "types": ["node"]
  },
  "include": ["src/**/*.ts", "src/**/*.vue", "tests/**/*.ts", "eslint.config.ts", "vite.config.ts"]
}
